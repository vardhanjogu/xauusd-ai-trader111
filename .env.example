# Broker & Market Data API Keys
OANDA_API_KEY=YOUR_OANDA_API_KEY
OANDA_ACCOUNT_ID=YOUR_OANDA_ACCOUNT_ID
TWELVEDATA_API_KEY=YOUR_TWELVEDATA_API_KEY
ALPHAVANTAGE_API_KEY=YOUR_ALPHAVANTAGE_API_KEY

# PostgreSQL Database
DATABASE_URL=postgresql://trading_user:trading_password@postgres_db:5432/xauusd_trading

# Redis (for API Gateway caching, WebSockets pub/sub)
REDIS_URL=redis://redis_cache:6379/0

# Google Cloud Platform (GCP)
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/app/auth/key.json
GCS_BUCKET_NAME=xauusd-ai-models-bucket

# Service Ports (Local mapping)
API_GATEWAY_PORT=8000
MARKET_DATA_PORT=8001
DATA_PIPELINE_PORT=8002
AI_MODEL_PORT=8003
STRATEGY_ENGINE_PORT=8004
RISK_MANAGER_PORT=8005
EXECUTION_PORT=8006
BACKTESTING_PORT=8007

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
